# ============================================================================
# Lablink Database Backup Configuration
# ============================================================================

# Number of days to keep local backups (older backups are deleted)
LL_RETENTION_DAYS=7

# Enable creation of compressed tar.gz archive of database data
LL_ARCHIVE_ENABLED=true

# Command to run for uploading backups to remote storage
# $LAST_BACKUP variable will contain the path to the backup file
LL_REMOTE_SYNC_CMD='/home/shampad/projects/lablink/lablink-backend/db/backup_utility/upload_to_gcs.sh "$LAST_BACKUP"'

# ============================================================================
# Google Cloud Storage (GCS) Configuration
# ============================================================================

# Name of the GCS bucket where backups will be stored
GCS_BUCKET_NAME=home-server-ss

# Folder/path within the bucket for organizing backups
GCS_BUCKET_PATH=lablink-backup

# Number of days to keep daily backups in GCS
GCS_RETENTION_DAYS=7

# Number of months to keep monthly archive backups in GCS.
# For backups outside the daily window, one backup per month is kept (the earliest of that month).
GCS_MONTHLY_RETENTION_MONTHS=12

# Path to GCS service account key JSON file for authentication
GCS_SERVICE_ACCOUNT_KEY=/home/shampad/projects/lablink/lablink-backend/env/service_accounts/gcs/gcs_sa.json
