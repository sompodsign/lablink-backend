# LabLink Production Environment Variables
# Copy this to .env and fill in actual values
# ─────────────────────────────────────────────

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=shampad.ddns.net,*.shampad.ddns.net,localhost

# Database (matches docker-compose service)
POSTGRES_DB=lablink
POSTGRES_USER=lablink_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Celery (matches docker-compose service)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# CORS — comma-separated allowed origins
CORS_ALLOWED_ORIGINS=http://shampad.ddns.net:4010,http://localhost:4010
CSRF_TRUSTED_ORIGINS=http://shampad.ddns.net:4010,http://localhost:4010
